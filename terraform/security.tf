resource "aws_security_group" "alb" {
  name        = "${var.project_name}-alb-sg"
  description = "Dopusta HTTP saobracaj sa interneta na ALB"
  vpc_id      = aws_vpc.main.id

  ingress {
    description = "HTTP sa interneta"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Svi izlazni saobracaj"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.project_name}-alb-sg"
  }
}

resource "aws_security_group" "ec2" {
  name        = "${var.project_name}-ec2-sg"
  description = "Dopusta HTTP iz ALB-a i SSH za upravljanje"
  vpc_id      = aws_vpc.main.id

  ingress {
    description     = "HTTP samo iz ALB Security Group-a"
    from_port       = 80
    to_port         = 80
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
  }

  ingress {
    description = "SSH za upravljanje"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Svi izlazni saobracaj"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.project_name}-ec2-sg"
  }
}

resource "aws_security_group" "rds" {
  name        = "${var.project_name}-rds-sg"
  description = "Dopusta PostgreSQL pristup samo sa EC2 instanci"
  vpc_id      = aws_vpc.main.id

  ingress {
    description     = "PostgreSQL samo iz EC2 Security Group-a"
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.ec2.id]
  }

  egress {
    description = "Svi izlazni saobracaj"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.project_name}-rds-sg"
  }
}
